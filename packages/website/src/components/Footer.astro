---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-name">Words Left Unsaid</span>
      <p class="footer-tagline">The things we carry in silence deserve to be heard.</p>
    </div>
    <div class="footer-links">
      <a href="/">Browse</a>
      <a href="/submit">Share yours</a>
      <a href="/about">About</a>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">&copy; {year} Words Left Unsaid</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-subtle);
    margin-top: var(--space-3xl);
    padding: var(--space-2xl) var(--space-lg);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    text-align: center;
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--text-primary);
    letter-spacing: 0.5px;
  }

  .footer-tagline {
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--text-muted);
    margin-top: var(--space-sm);
    font-style: italic;
  }

  .footer-links {
    display: flex;
    gap: var(--space-xl);
  }

  .footer-links a {
    font-size: 13px;
    color: var(--text-secondary);
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: color var(--duration-fast);
  }

  .footer-links a:hover {
    color: var(--text-primary);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .footer-bottom {
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border-subtle);
    width: 100%;
  }

  .footer-copy {
    font-size: 12px;
    color: var(--text-muted);
  }
</style>
