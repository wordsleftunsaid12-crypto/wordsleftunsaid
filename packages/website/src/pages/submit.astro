---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  createApprovedMessage,
  sanitizeMessageInput,
  moderateContent,
  notifyMessageApproved,
} from '@wlu/shared';

let submitted = false;
let formError = '';
let messageId = '';
let submittedTo = '';
let submittedFrom = '';
let submittedContent = '';

const formToken = Date.now().toString(36);

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();

    // Honeypot: bots fill hidden fields, real users don't
    const honeypot = formData.get('website')?.toString() || '';
    if (honeypot) {
      submitted = true; // Fake success so bots don't retry
    } else {
      // Timing check: reject submissions faster than 3 seconds
      const token = formData.get('_token')?.toString() || '';
      const tokenTime = parseInt(token, 36);
      const elapsed = Date.now() - tokenTime;

      if (!token || isNaN(tokenTime) || elapsed < 3000) {
        formError = 'Please take your time. Try submitting again.';
      } else {
        const rawFrom = formData.get('from')?.toString() || '';
        const rawTo = formData.get('to')?.toString() || '';
        const rawContent = formData.get('content')?.toString() || '';
        const rawEmail = formData.get('email')?.toString() || '';

        const sanitized = sanitizeMessageInput({
          from: rawFrom,
          to: rawTo,
          content: rawContent,
          email: rawEmail || undefined,
        });

        if (!sanitized.from || !sanitized.to || !sanitized.content) {
          formError = 'Please fill in all required fields.';
        } else if (sanitized.content.length < 10) {
          formError = 'Your message is too short. Say a little more.';
        } else {
          const moderation = moderateContent(sanitized.content, sanitized.from, sanitized.to);

          if (!moderation.passed) {
            const isQuality = moderation.reasons.some((r) => r.startsWith('low-effort') || r.startsWith('casual') || r.startsWith('too many repeated') || r.startsWith('mostly non-letter'));
            formError = isQuality
              ? 'This space is for words that matter. Take a moment and write something real.'
              : 'This message can\u2019t be posted. Please keep it respectful.';
          } else {
            const message = await createApprovedMessage(sanitized);
            submitted = true;
            messageId = message.id;
            submittedTo = sanitized.to;
            submittedFrom = sanitized.from;
            submittedContent = sanitized.content;

            // Send email notification (fire-and-forget, don't block the response)
            if (sanitized.email) {
              notifyMessageApproved({
                messageId: message.id,
                email: sanitized.email,
                to: sanitized.to,
                siteUrl: import.meta.env.SITE || 'https://wordsleftunsaid.netlify.app',
              }).catch(() => {});
            }
          }
        }
      }
    }
  } catch (e) {
    formError = 'Something went wrong. Please try again.';
  }
}
---

<Base
  title="Share Your Words | Words Left Unsaid"
  description="Write the message you never sent. Share anonymously."
>
  <Header />

  <main class="submit-page">
    <div class="container">
      {submitted ? (
        <div class="success-state fade-in">
          <div class="success-icon" aria-hidden="true">&ldquo;</div>
          <h1 class="success-title">Your words are free now.</h1>
          <p class="success-text">
            Thank you for letting them out. Your message is live.
          </p>

          {/* Preview card */}
          {messageId && (
            <div class="share-preview-card">
              <div class="share-card-accent"></div>
              <div class="share-card-body">
                <div class="share-card-to">
                  <span class="share-card-label">To</span>
                  <span class="share-card-name">{submittedTo}</span>
                </div>
                <p class="share-card-content">
                  {submittedContent.length > 140
                    ? submittedContent.slice(0, 140).trimEnd() + '...'
                    : submittedContent}
                </p>
                <span class="share-card-from">&mdash; {submittedFrom}</span>
              </div>
            </div>
          )}

          {/* Share section */}
          {messageId && (
            <div class="share-section">
              <span class="share-heading">Share your message</span>
              <div class="share-buttons" id="share-buttons">
                <button class="share-btn" id="copy-share-link" aria-label="Copy link">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                  </svg>
                  <span>Copy link</span>
                </button>
                <a class="share-btn" id="share-x" href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on X">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                  </svg>
                  <span>Share on X</span>
                </a>
                <a class="share-btn" id="share-fb" href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                  </svg>
                  <span>Facebook</span>
                </a>
                <a class="share-btn" id="share-wa" href="#" target="_blank" rel="noopener noreferrer" aria-label="Share on WhatsApp">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                  </svg>
                  <span>WhatsApp</span>
                </a>
                <button class="share-btn" id="native-share-btn" style="display: none;" aria-label="Share">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="18" cy="5" r="3" /><circle cx="6" cy="12" r="3" /><circle cx="18" cy="19" r="3" />
                    <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" /><line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
                  </svg>
                  <span>Share</span>
                </button>
              </div>
            </div>
          )}

          <div class="success-actions">
            {messageId && <a href={`/messages/${messageId}`} class="btn-view">View your message</a>}
            <a href="/submit" class="btn-ghost">Write another</a>
            <a href="/" class="btn-ghost">Browse messages</a>
          </div>

          {messageId && (
            <script is:inline define:vars={{ messageId, submittedTo, submittedContent }}>
              if (typeof gtag !== 'undefined') {
                gtag('event', 'message_submit', { message_id: messageId });
              }

              var siteUrl = window.location.origin;
              var msgUrl = siteUrl + '/messages/' + messageId;
              var truncTo = submittedTo.length > 20 ? submittedTo.slice(0, 20) + '...' : submittedTo;
              var truncContent = submittedContent.length > 80 ? submittedContent.slice(0, 80).trimEnd() + '...' : submittedContent;
              var shareText = '"To ' + truncTo + '..." \u2014 read it on Words Left Unsaid';

              // Set share URLs
              var xLink = document.getElementById('share-x');
              if (xLink) xLink.href = 'https://twitter.com/intent/tweet?text=' + encodeURIComponent(shareText) + '&url=' + encodeURIComponent(msgUrl);

              var fbLink = document.getElementById('share-fb');
              if (fbLink) fbLink.href = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(msgUrl);

              var waLink = document.getElementById('share-wa');
              if (waLink) waLink.href = 'https://wa.me/?text=' + encodeURIComponent(shareText + ' ' + msgUrl);

              function trackShareSubmit(method) {
                if (typeof gtag !== 'undefined') {
                  gtag('event', 'share_after_submit', { method: method, message_id: messageId });
                }
              }

              // Copy link
              var copyBtn = document.getElementById('copy-share-link');
              if (copyBtn) {
                copyBtn.addEventListener('click', function() {
                  navigator.clipboard.writeText(msgUrl);
                  trackShareSubmit('copy_link');
                  var textEl = copyBtn.querySelector('span');
                  if (textEl) {
                    textEl.textContent = 'Copied!';
                    copyBtn.classList.add('copied');
                    setTimeout(function() {
                      textEl.textContent = 'Copy link';
                      copyBtn.classList.remove('copied');
                    }, 2000);
                  }
                });
              }

              // Track social clicks
              ['share-x', 'share-fb', 'share-wa'].forEach(function(id) {
                var el = document.getElementById(id);
                if (el) el.addEventListener('click', function() {
                  trackShareSubmit(id.replace('share-', ''));
                });
              });

              // Native share
              var nativeBtn = document.getElementById('native-share-btn');
              if (navigator.share && nativeBtn) {
                nativeBtn.style.display = 'inline-flex';
                nativeBtn.addEventListener('click', function() {
                  trackShareSubmit('native');
                  navigator.share({ title: 'Words Left Unsaid', text: shareText, url: msgUrl });
                });
              }
            </script>
          )}
        </div>
      ) : (
        <div class="form-container">
          <div class="form-header fade-in">
            <h1 class="form-title">Say what you never could.</h1>
            <p class="form-subtitle">
              This is a safe, anonymous space. No one will know who wrote this &mdash;
              but the words will finally exist outside of you.
            </p>
          </div>

          <form method="POST" class="message-form fade-in" id="submit-form">
            {formError && (
              <div class="form-error" role="alert">{formError}</div>
            )}

            {/* Honeypot — invisible to real users, bots fill it */}
            <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;">
              <label for="website">Website</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>
            <input type="hidden" name="_token" value={formToken} />

            <div class="form-row">
              <div class="form-group">
                <label for="to" class="form-label">To</label>
                <input
                  type="text"
                  id="to"
                  name="to"
                  placeholder="The person, the place, the feeling..."
                  maxlength="25"
                  required
                  class="form-input"
                />
              </div>
              <div class="form-group">
                <label for="from" class="form-label">From</label>
                <input
                  type="text"
                  id="from"
                  name="from"
                  placeholder="A name, a stranger, anonymous..."
                  maxlength="25"
                  required
                  class="form-input"
                />
              </div>
            </div>

            <div class="form-group">
              <label for="content" class="form-label">Your message</label>
              <textarea
                id="content"
                name="content"
                placeholder="Write the words you've been holding inside..."
                maxlength="500"
                rows="8"
                required
                class="form-textarea"
              ></textarea>
              <div class="char-count">
                <span id="char-current">0</span> / 500
              </div>
            </div>

            <div class="form-group">
              <label for="email" class="form-label form-label-optional">
                Email <span class="optional-tag">optional</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="Only if you want to be notified"
                class="form-input"
              />
              <p class="form-hint">We'll only use this to notify you when your message is live. Never shared.</p>
            </div>

            <button type="submit" class="btn-submit" id="submit-btn">
              Let it go
            </button>
          </form>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Base>

<script>
  const textarea = document.getElementById('content') as HTMLTextAreaElement | null;
  const counter = document.getElementById('char-current');
  const form = document.getElementById('submit-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  textarea?.addEventListener('input', () => {
    if (counter) counter.textContent = String(textarea.value.length);
  });

  form?.addEventListener('submit', () => {
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      submitBtn.style.opacity = '0.7';
    }
  });
</script>

<style>
  .submit-page {
    padding: var(--space-3xl) 0;
    min-height: 80vh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  .form-container {
    max-width: 600px;
    margin: 0 auto;
    width: 100%;
  }

  .form-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .form-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }

  .form-subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto;
  }

  /* Form */
  .message-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .form-error {
    padding: var(--space-md) var(--space-lg);
    background: rgba(230, 57, 70, 0.08);
    border: 1px solid rgba(230, 57, 70, 0.2);
    border-radius: var(--radius-sm);
    color: #e63946;
    font-size: 14px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .form-label {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--text-muted);
  }

  .form-label-optional {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .optional-tag {
    font-size: 10px;
    text-transform: lowercase;
    letter-spacing: 0;
    color: var(--text-muted);
    opacity: 0.6;
    font-weight: 400;
  }

  .form-input,
  .form-textarea {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-sm);
    padding: 14px 16px;
    transition:
      border-color var(--duration-fast),
      box-shadow var(--duration-fast);
    outline: none;
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--text-muted);
    opacity: 0.6;
  }

  .form-input:focus,
  .form-textarea:focus {
    border-color: var(--brand-warm);
    box-shadow: 0 0 0 3px rgba(200, 168, 130, 0.15), inset 0 1px 2px rgba(200, 168, 130, 0.05);
  }

  .form-textarea {
    resize: vertical;
    min-height: 260px;
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.7;
  }

  .char-count {
    font-size: 12px;
    color: var(--text-muted);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .form-hint {
    font-size: 12px;
    color: var(--text-muted);
    opacity: 0.7;
  }

  .btn-submit {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 1px;
    padding: 16px 32px;
    background: var(--brand-warm);
    color: #0c0b0a;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition:
      background var(--duration-fast),
      transform var(--duration-fast);
    align-self: center;
  }

  .btn-submit:hover {
    background: var(--brand-gold);
    transform: translateY(-1px);
  }

  /* Success State */
  .success-state {
    text-align: center;
    max-width: 500px;
    margin: 0 auto;
    padding: var(--space-2xl) 0;
  }

  .success-icon {
    font-family: var(--font-display);
    font-size: 80px;
    line-height: 1;
    color: var(--brand-warm);
    opacity: 0.3;
    margin: 0 auto var(--space-md);
  }

  .success-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }

  .success-text {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  /* Share preview card */
  .share-preview-card {
    background: rgba(26, 24, 22, 0.6);
    border: 1px solid rgba(200, 168, 130, 0.1);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: var(--space-xl);
    text-align: left;
  }

  :global([data-theme='light']) .share-preview-card {
    background: rgba(255, 255, 255, 0.7);
    border-color: rgba(140, 110, 90, 0.1);
  }

  .share-card-accent {
    height: 3px;
    background: linear-gradient(90deg, var(--brand-warm) 0%, var(--brand-gold) 100%);
    opacity: 0.7;
  }

  .share-card-body {
    padding: var(--space-lg);
  }

  .share-card-to {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .share-card-label {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--text-muted);
  }

  .share-card-name {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 1px;
    color: var(--text-accent);
  }

  .share-card-content {
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.6;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
    white-space: pre-line;
  }

  .share-card-from {
    font-size: 13px;
    color: var(--text-secondary);
    font-style: italic;
  }

  /* Share section */
  .share-section {
    margin-bottom: var(--space-xl);
  }

  .share-heading {
    display: block;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-muted);
    margin-bottom: var(--space-md);
  }

  .share-buttons {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-size: 12px;
    cursor: pointer;
    text-decoration: none;
    transition:
      color var(--duration-fast),
      border-color var(--duration-fast),
      background var(--duration-fast);
  }

  .share-btn:hover {
    color: var(--text-primary);
    border-color: var(--text-muted);
    background: var(--bg-card-hover);
  }

  .share-btn.copied {
    color: var(--brand-warm);
    border-color: var(--brand-warm);
  }

  .success-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-view {
    display: inline-block;
    padding: 12px 28px;
    background: var(--brand-warm);
    color: #0c0b0a;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition:
      background var(--duration-fast),
      transform var(--duration-fast);
  }

  .btn-view:hover {
    background: var(--brand-gold);
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-block;
    padding: 12px 28px;
    border: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-size: 14px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition:
      border-color var(--duration-fast),
      color var(--duration-fast);
  }

  .btn-ghost:hover {
    border-color: var(--text-muted);
    color: var(--text-primary);
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .submit-page {
      padding: var(--space-2xl) 0;
    }
  }
</style>
